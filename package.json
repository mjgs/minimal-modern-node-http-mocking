  "license": "ISC",
  "type": "module",
  "dependencies": {
    "express": "^5.2.1",
    "node-fetch": "^3.3.2",
    "octokit": "^5.0.5"
  },
  "devDependencies": {
    "@pollyjs/adapter-fetch": "^6.0.7",
    "@pollyjs/adapter-node-http": "^6.0.6",
    "@pollyjs/core": "^6.0.6",
    "@pollyjs/persister-fs": "^6.0.6",
    "axios": "^1.16.0",
    "nock": "^14.0.15"
  }
}
