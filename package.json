{
  "name": "modern-node-http-mocking",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "npm run test:nock; npm run test:poly",
    "test:nock": "node --test --test-reporter=spec test/nock/server.test.js",
    "test:poly": "node --test --test-concurrency=1 test/poly/server.test.js",
    "test:all": "node --test --test-concurrency=1 test/**/*.test.js"
  },
  "keywords": [],
